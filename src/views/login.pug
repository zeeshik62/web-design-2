extends layout

block styles
    style.
        .auth-box {
            max-width: 450px;
            margin: 6rem auto;
            background: var(--card-bg);
            padding: 3rem;
            border-radius: 20px;
            border: 1px solid var(--border);
            box-shadow: 0 20px 40px rgba(0,0,0,0.4);
        }
        .auth-box h1 {
            text-align: center;
            margin-bottom: 2rem;
            font-size: 2rem;
            color: #fff;
        }
        .form-group {
            margin-bottom: 1.5rem;
        }
        .form-group label {
            display: block;
            margin-bottom: 0.5rem;
            color: var(--text-secondary);
            font-size: 0.9rem;
        }
        .form-control {
            width: 100%;
            background: var(--bg-dark);
            border: 1px solid var(--border);
            padding: 0.75rem 1rem;
            border-radius: 10px;
            color: #fff;
            outline: none;
            transition: border-color 0.3s;
        }
        .form-control:focus {
            border-color: var(--primary);
        }
        .auth-btn {
            width: 100%;
            padding: 1rem;
            margin-top: 1rem;
            font-size: 1rem;
        }
        .auth-footer {
            margin-top: 2rem;
            text-align: center;
            color: var(--text-secondary);
            font-size: 0.9rem;
        }
        .auth-footer a {
            color: var(--primary);
            text-decoration: none;
        }

block content
    div.container
        div.auth-box
            h1 User Login
            form#user-login-form
                div.form-group
                    label(for="email") Email Address
                    input#email.form-control(type="email" placeholder="user@example.com" required)
                div.form-group
                    label(for="password") Password
                    input#password.form-control(type="password" placeholder="••••••••" required)
                button.btn.btn-primary.auth-btn(type="submit") Login
            
            div.auth-footer
                p Don't have an account? 
                    a(href="/register") Sign Up

block scripts
    script.
        const loginForm = document.getElementById('user-login-form');
        loginForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const email = document.getElementById('email').value;
            const password = document.getElementById('password').value;
            
            const success = await HMS.loginCustomer(email, password);
            if (success) {
                HMS.notify('Welcome back! Redirecting to halls...', 'success');
                setTimeout(() => window.location.href = '/halls', 1500);
            }
        });
