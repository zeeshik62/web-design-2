extends layout

block styles
    style.
        .vendor-card {
            background: var(--card-bg);
            border-radius: 20px;
            border: 1px solid var(--border);
            overflow: hidden;
            transition: all 0.35s ease;
            cursor: pointer;
            position: relative;
        }
        .vendor-card:hover {
            transform: translateY(-6px);
            border-color: var(--primary);
            box-shadow: 0 20px 40px rgba(99, 102, 241, 0.15);
        }
        .vendor-img {
            height: 200px;
            background: linear-gradient(135deg, var(--primary), var(--accent-purple));
            position: relative;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 3.5rem;
            color: rgba(255,255,255,0.2);
        }
        .vendor-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            position: absolute;
            top: 0; left: 0;
            transition: transform 0.4s ease;
        }
        .vendor-card:hover .vendor-img img {
            transform: scale(1.07);
        }
        .vendor-category-badge {
            position: absolute;
            top: 1rem;
            left: 1rem;
            background: rgba(99, 102, 241, 0.85);
            backdrop-filter: blur(8px);
            color: white;
            padding: 0.3rem 0.9rem;
            border-radius: 50px;
            font-size: 0.75rem;
            font-weight: 700;
            letter-spacing: 0.5px;
            z-index: 5;
            border: 1px solid rgba(255,255,255,0.15);
        }
        .vendor-content {
            padding: 1.5rem;
        }
        .vendor-content h4 {
            font-size: 1.2rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .vendor-meta {
            display: flex;
            gap: 1rem;
            margin: 0.75rem 0;
            color: var(--text-secondary);
            font-size: 0.875rem;
            flex-wrap: wrap;
        }
        .vendor-meta span {
            display: flex;
            align-items: center;
            gap: 0.4rem;
        }
        .vendor-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 1rem;
            padding-top: 1rem;
            border-top: 1px solid var(--border);
        }
        .staff-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
            padding: 0.25rem 0.75rem;
            background: rgba(74, 222, 128, 0.08);
            border: 1px solid rgba(74, 222, 128, 0.2);
            color: var(--accent-green);
            border-radius: 50px;
            font-size: 0.75rem;
            font-weight: 600;
        }
        .result-count {
            color: var(--text-secondary);
            font-size: 0.9rem;
            margin-bottom: 1.5rem;
            padding-left: 0.25rem;
        }
        .result-count span {
            color: var(--primary);
            font-weight: 700;
        }
        .no-results {
            grid-column: 1 / -1;
            text-align: center;
            padding: 5rem 2rem;
        }
        .no-results i {
            font-size: 3rem;
            color: var(--text-secondary);
            margin-bottom: 1.5rem;
            display: block;
            opacity: 0.4;
        }
        .no-results h3 {
            font-size: 1.5rem;
            margin-bottom: 0.75rem;
        }
        .no-results p {
            color: var(--text-secondary);
        }

block content
    div.container
        div.page-header
            h1 Discover Vendors
            p.text-secondary(style="font-size: 1.1rem;") Find top-rated caterers, photographers, decorators and more for your events.

        div.filters-container
            div.filter-bar
                div.filter-item
                    label Vendor Name
                    div.input-with-icon
                        i.fas.fa-magnifying-glass
                        input#filter-name(type="text" placeholder="Search by name...")

                div.filter-item
                    label Category
                    div.input-with-icon
                        i.fas.fa-tags
                        select#filter-category
                            option(value="") All Categories
                            option(value="Caterer") Caterer
                            option(value="Photographer") Photographer
                            option(value="Decorator") Decorator
                            option(value="DJ") DJ
                            option(value="Live Band") Live Band
                            option(value="Event Planner") Event Planner
                            option(value="Make-up Artist") Make-up Artist

                div.filter-item
                    label City
                    div.input-with-icon
                        i.fas.fa-city
                        input#filter-city(type="text" placeholder="e.g. London")

                div.filter-item
                    label Staff
                    div.input-with-icon
                        i.fas.fa-user-friends
                        select#filter-staff
                            option(value="") All Staff
                            option(value="Male") Male Only
                            option(value="Female") Female Only
                            option(value="Both") Both

                button.btn-primary#apply-filters
                    i.fas.fa-filter
                    span Filter

        p#result-count.result-count(style="display:none;") Showing &nbsp;
            span#count-value 0
            | &nbsp;vendors

        div#vendors-grid.grid
            div.loading-spinner(style="grid-column: 1 / -1; text-align: center; padding: 4rem 0; color: var(--text-secondary);")
                i.fas.fa-circle-notch.fa-spin(style="font-size: 2rem; color: var(--primary); margin-bottom: 1rem; display: block;")
                span Loading services...

block scripts
    script.
        document.addEventListener('DOMContentLoaded', () => {
            const urlParams = new URLSearchParams(window.location.search);
            const name     = urlParams.get('search');
            const city     = urlParams.get('city');
            const category = urlParams.get('category');
            const staff    = urlParams.get('staff');

            if (name)     document.getElementById('filter-name').value     = name;
            if (city)     document.getElementById('filter-city').value     = city;
            if (category) document.getElementById('filter-category').value = category;
            if (staff)    document.getElementById('filter-staff').value    = staff;

            const filters = {
                search:   name     || '',
                city:     city     || '',
                category: category || '',
                staff:    staff    || ''
            };

            if (window.renderVendorListing) window.renderVendorListing(filters);

            document.getElementById('apply-filters').addEventListener('click', () => {
                const filters = {
                    search:   document.getElementById('filter-name').value.trim(),
                    city:     document.getElementById('filter-city').value.trim(),
                    category: document.getElementById('filter-category').value,
                    staff:    document.getElementById('filter-staff').value
                };

                if (window.renderVendorListing) {
                    window.renderVendorListing(filters);
                    const newUrl = new URL(window.location);
                    Object.keys(filters).forEach(key => {
                        if (filters[key]) newUrl.searchParams.set(key, filters[key]);
                        else newUrl.searchParams.delete(key);
                    });
                    window.history.pushState({}, '', newUrl);
                }
            });

            // Allow enter key to trigger filter
            ['filter-name','filter-city'].forEach(id => {
                document.getElementById(id).addEventListener('keydown', (e) => {
                    if (e.key === 'Enter') document.getElementById('apply-filters').click();
                });
            });
        });
