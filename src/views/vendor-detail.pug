extends layout

block styles
    style.
        .detail-header {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 3rem;
            margin-bottom: 4rem;
        }
        .main-image {
            width: 100%;
            height: 450px;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 20px 40px rgba(0,0,0,0.3);
            position: relative;
        }
        .main-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .image-gallery {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 0.75rem;
            margin-top: 1rem;
        }
        .gallery-thumb {
            height: 80px;
            border-radius: 12px;
            overflow: hidden;
            cursor: pointer;
            border: 2px solid transparent;
            transition: all 0.2s ease;
        }
        .gallery-thumb.active {
            border-color: var(--primary);
        }
        .gallery-thumb img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .info-panel {
            display: flex;
            flex-direction: column;
            justify-content: center;
        }
        .vendor-type-tag {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.5rem 1.5rem;
            background: rgba(99, 102, 241, 0.1);
            color: var(--primary);
            border-radius: 50px;
            font-weight: 700;
            margin-bottom: 1.5rem;
            border: 1px solid rgba(99, 102, 241, 0.2);
            width: fit-content;
        }
        .detail-stats {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
            gap: 1rem;
            margin: 2rem 0;
        }
        .detail-stat {
            background: var(--card-bg);
            padding: 1.25rem;
            border-radius: 15px;
            border: 1px solid var(--border);
            display: flex;
            align-items: center;
            gap: 0.875rem;
            transition: border-color 0.3s ease;
        }
        .detail-stat:hover {
            border-color: var(--primary);
        }
        .detail-stat i {
            font-size: 1.4rem;
            color: var(--primary);
            flex-shrink: 0;
        }
        .detail-stat .stat-label {
            font-size: 0.78rem;
            color: var(--text-secondary);
            margin-bottom: 0.2rem;
        }
        .detail-stat strong {
            font-size: 1rem;
        }
        .section-title {
            font-size: 1.6rem;
            margin-bottom: 1.5rem;
            border-left: 4px solid var(--primary);
            padding-left: 1rem;
        }
        .instructions-card {
            background: var(--card-bg);
            padding: 2rem;
            border-radius: 20px;
            border: 1px solid var(--border);
            margin-bottom: 4rem;
            line-height: 1.8;
            color: var(--text-secondary);
        }
        .owner-card {
            background: var(--card-bg);
            padding: 2rem;
            border-radius: 20px;
            border: 1px solid var(--border);
            margin-bottom: 4rem;
            display: flex;
            align-items: center;
            gap: 1.5rem;
        }
        .owner-avatar {
            width: 70px;
            height: 70px;
            background: linear-gradient(135deg, var(--primary), var(--accent-purple));
            border-radius: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.75rem;
            font-weight: 700;
            color: white;
            flex-shrink: 0;
        }
        .owner-info h3 {
            font-size: 1.1rem;
            margin-bottom: 0.25rem;
        }
        .owner-info p {
            color: var(--text-secondary);
            font-size: 0.9rem;
        }
        .action-btns {
            display: flex;
            flex-direction: column;
            gap: 1rem;
            margin-top: 2rem;
        }
        .action-btns .btn {
            width: 100%;
            font-size: 1rem;
            padding: 0.9rem 1.5rem;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.6rem;
            border-radius: 14px;
        }
        .btn-whatsapp {
            background: rgba(37, 211, 102, 0.1);
            color: #25d366;
            border: 1px solid rgba(37, 211, 102, 0.3);
        }
        .btn-whatsapp:hover {
            background: rgba(37, 211, 102, 0.2);
        }
        @media (max-width: 768px) {
            .detail-header { grid-template-columns: 1fr; }
            .main-image { height: 300px; }
        }

block content
    style.
        .modal-overlay {
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0,0,0,0.7);
            z-index: 2000;
            display: none;
            align-items: center;
            justify-content: center;
        }
        .modal {
            background: var(--card-bg);
            padding: 2.5rem;
            border-radius: 20px;
            width: 100%;
            max-width: 450px;
            border: 1px solid var(--border);
            position: relative;
        }
        .close-btn {
            position: absolute;
            top: 1rem;
            right: 1.5rem;
            font-size: 1.5rem;
            cursor: pointer;
            color: var(--text-secondary);
        }
        .modal input, .modal textarea {
            width: 100%;
            background: var(--bg-dark);
            border: 1px solid var(--border);
            padding: 0.75rem;
            border-radius: 10px;
            color: #fff;
            margin-top: 0.5rem;
            font-family: inherit;
        }

    //- Auth Modal
    div#auth-modal.modal-overlay
        div.modal
            span.close-btn(onclick="closeModal('auth-modal')") &times;
            h2#auth-title(style="margin-bottom: 1.5rem;") Login
            div#login-form-area
                form#customer-login-form
                    div(style="margin-bottom: 1rem;")
                        label Email Address
                        input(type="email" name="email" required)
                    div(style="margin-bottom: 1.5rem;")
                        label Password
                        input(type="password" name="password" required)
                    button.btn.btn-primary(type="submit" style="width: 100%") Login
                p(style="margin-top: 1rem; text-align: center; color: var(--text-secondary);") Don't have an account?
                    a(href="#" onclick="switchAuthMode()" style="color: var(--primary); text-decoration: none;") &nbsp;Register
            div#register-form-area(style="display: none;")
                form#customer-register-form
                    div(style="margin-bottom: 1rem;")
                        label Full Name
                        input(type="text" name="name" required)
                    div(style="margin-bottom: 1rem;")
                        label Email Address
                        input(type="email" name="email" required)
                    div(style="margin-bottom: 1.5rem;")
                        label Password
                        input(type="password" name="password" required)
                    button.btn.btn-primary(type="submit" style="width: 100%") Register
                p(style="margin-top: 1rem; text-align: center; color: var(--text-secondary);") Already have an account?
                    a(href="#" onclick="switchAuthMode()" style="color: var(--primary); text-decoration: none;") &nbsp;Login

    //- Vendor Query Modal
    div#query-modal.modal-overlay
        div.modal
            span.close-btn(onclick="closeModal('query-modal')") &times;
            h2(style="margin-bottom: 0.5rem;") Send an Enquiry
            p(style="color: var(--text-secondary); font-size: 0.9rem; margin-bottom: 1.5rem;") Tell the vendor about your requirements.
            form#vendor-query-form
                input#query-vendor-slug(type="hidden")
                div(style="margin-bottom: 1rem;")
                    label Event / Service Date
                    input(type="date" name="date" required)
                div(style="margin-bottom: 1.5rem;")
                    label Describe your requirements
                    textarea(name="description" rows="4" placeholder="e.g. Number of guests, occasion type, preferences..." required)
                button.btn.btn-primary(type="submit" style="width: 100%") Submit Enquiry

    div#vendor-detail-container.container
        div.loading-spinner(style="text-align: center; padding: 6rem 0;")
            i.fas.fa-circle-notch.fa-spin(style="font-size: 2.5rem; color: var(--primary); margin-bottom: 1rem; display: block;")
            span Fetching vendor details...

block scripts
    script.
        async function renderVendorDetailPage() {
            const slug = window.location.pathname.split('/').pop();
            const container = document.getElementById('vendor-detail-container');

            const vendor = await HMS.fetchVendorBySlug(slug);
            if (!vendor) {
                container.innerHTML = `
                    <div style="text-align:center; padding: 6rem 0;">
                        <i class="fas fa-triangle-exclamation" style="font-size:3rem; color: var(--accent-orange); margin-bottom:1rem; display:block;"></i>
                        <h2>Vendor not found</h2>
                        <p style="color: var(--text-secondary); margin: 1rem 0 2rem;">This vendor may no longer be available.</p>
                        <a href="/vendors" class="btn btn-primary">Browse All Vendors</a>
                    </div>`;
                return;
            }

            const images = vendor.images && vendor.images.length > 0 ? vendor.images : [];
            const mainImg = images[0] || 'https://via.placeholder.com/800x600?text=No+Image';
            const ownerInitial = (vendor.vendor_id && vendor.vendor_id.name) ? vendor.vendor_id.name.charAt(0).toUpperCase() : 'V';

            const categoryIcons = {
                'Caterer': 'fa-utensils',
                'Photographer': 'fa-camera',
                'Decorator': 'fa-wand-magic-sparkles',
                'DJ': 'fa-music',
                'Live Band': 'fa-guitar',
                'Event Planner': 'fa-calendar-check',
                'Make-up Artist': 'fa-brush'
            };
            const catIcon = categoryIcons[vendor.category] || 'fa-briefcase';

            const thumbsHtml = images.length > 1 ? `
                <div class="image-gallery">
                    ${images.map((img, i) => `
                        <div class="gallery-thumb ${i === 0 ? 'active' : ''}" onclick="switchImage('${img}', this)">
                            <img src="${img}" alt="Vendor image ${i+1}">
                        </div>
                    `).join('')}
                </div>` : '';

            container.innerHTML = `
                <div style="margin-bottom: 1.5rem;">
                    <a href="/vendors" style="color: var(--text-secondary); text-decoration: none; display:inline-flex; align-items:center; gap:0.5rem; font-size:0.9rem; transition:color 0.2s;" onmouseover="this.style.color='var(--primary)'" onmouseout="this.style.color='var(--text-secondary)'">
                        <i class="fas fa-arrow-left"></i> Back to Vendors
                    </a>
                </div>

                <div class="detail-header">
                    <div>
                        <div class="main-image">
                            <img id="main-vendor-img" src="${mainImg}" alt="${vendor.vendor_name}">
                            ${vendor.discount ? `<div class="discount-badge">-${vendor.discount}% OFF</div>` : ''}
                        </div>
                        ${thumbsHtml}
                    </div>

                    <div class="info-panel">
                        <div class="vendor-type-tag">
                            <i class="fas ${catIcon}"></i>
                            ${vendor.category}
                        </div>

                        <h1 class="view-title" style="margin-bottom:0.75rem;">${vendor.vendor_name}</h1>
                        <p style="color: var(--text-secondary); display:flex; align-items:center; gap:0.5rem; margin-bottom:0.5rem;">
                            <i class="fas fa-location-dot" style="color:var(--primary);"></i>
                            ${vendor.address.street_address}, ${vendor.address.city}, ${vendor.address.country}
                        </p>

                        <div class="detail-stats">
                            <div class="detail-stat">
                                <i class="fas fa-money-bill-wave"></i>
                                <div>
                                    <p class="stat-label">Starting Price</p>
                                    <strong>Rs. ${vendor.starting_price.toLocaleString()}</strong>
                                    ${vendor.discount ? `<span style="display:block; font-size:0.75rem; color:#ef4444; font-weight:700;">-${vendor.discount}% OFF</span>` : ''}
                                </div>
                            </div>
                            <div class="detail-stat">
                                <i class="fas fa-user-friends"></i>
                                <div>
                                    <p class="stat-label">Staff</p>
                                    <strong>${vendor.staff}</strong>
                                </div>
                            </div>
                            <div class="detail-stat">
                                <i class="fas ${catIcon}"></i>
                                <div>
                                    <p class="stat-label">Category</p>
                                    <strong>${vendor.category}</strong>
                                </div>
                            </div>
                        </div>

                        <div class="action-btns">
                            <button class="btn btn-primary" onclick="handleContactClick('${vendor.slug}')">
                                <i class="fas fa-envelope"></i> Send Enquiry
                            </button>
                            ${vendor.vendor_id && vendor.vendor_id.contact ? `
                            <button class="btn btn-whatsapp" onclick="handleWhatsAppClick('${vendor.vendor_id.contact}')">
                                <i class="fab fa-whatsapp"></i> Contact on WhatsApp
                            </button>` : ''}
                        </div>
                    </div>
                </div>

                ${vendor.instructions ? `
                <h3 class="section-title">Service Description</h3>
                <div class="instructions-card">${vendor.instructions}</div>` : ''}

                ${vendor.vendor_id ? `
                <h3 class="section-title">Provided By</h3>
                <div class="owner-card">
                    <div class="owner-avatar">${ownerInitial}</div>
                    <div class="owner-info">
                        <h3>${vendor.vendor_id.brand_name || vendor.vendor_id.name || 'Hall Owner'}</h3>
                        <p><i class="fas fa-location-dot" style="margin-right:0.4rem;"></i>${vendor.vendor_id.address ? vendor.vendor_id.address.city + ', ' + vendor.vendor_id.address.country : 'Location not specified'}</p>
                    </div>
                </div>` : ''}
            `;
        }

        function switchImage(src, el) {
            document.getElementById('main-vendor-img').src = src;
            document.querySelectorAll('.gallery-thumb').forEach(t => t.classList.remove('active'));
            el.classList.add('active');
        }

        function openModal(id) {
            document.getElementById(id).style.display = 'flex';
        }
        function closeModal(id) {
            document.getElementById(id).style.display = 'none';
        }
        function switchAuthMode() {
            const loginArea    = document.getElementById('login-form-area');
            const registerArea = document.getElementById('register-form-area');
            const title        = document.getElementById('auth-title');
            if (loginArea.style.display === 'none') {
                loginArea.style.display    = 'block';
                registerArea.style.display = 'none';
                title.innerText = 'Login';
            } else {
                loginArea.style.display    = 'none';
                registerArea.style.display = 'block';
                title.innerText = 'Register';
            }
        }
        function checkAuth() {
            return !!localStorage.getItem('hms_customer_token');
        }
        function handleContactClick(slug) {
            if (!checkAuth()) { openModal('auth-modal'); return; }
            document.getElementById('query-vendor-slug').value = slug;
            openModal('query-modal');
        }
        function handleWhatsAppClick(contact) {
            if (!checkAuth()) { openModal('auth-modal'); return; }
            const clean = contact.replace(/\D/g, '');
            window.open(`https://wa.me/${clean}`, '_blank');
        }

        document.getElementById('vendor-query-form').onsubmit = async (e) => {
            e.preventDefault();
            const data = Object.fromEntries(new FormData(e.target));
            data.vendor_slug = document.getElementById('query-vendor-slug').value;
            const ok = await HMS.submitVendorQuery(data);
            if (ok) {
                closeModal('query-modal');
                e.target.reset();
            }
        };

        document.getElementById('customer-login-form').onsubmit = async (e) => {
            e.preventDefault();
            const data = Object.fromEntries(new FormData(e.target));
            const ok = await HMS.loginCustomer(data.email, data.password);
            if (ok) { closeModal('auth-modal'); HMS.notify('Logged in!'); }
        };
        document.getElementById('customer-register-form').onsubmit = async (e) => {
            e.preventDefault();
            const data = Object.fromEntries(new FormData(e.target));
            const ok = await HMS.registerCustomer(data);
            if (ok) switchAuthMode();
        };

        renderVendorDetailPage();
