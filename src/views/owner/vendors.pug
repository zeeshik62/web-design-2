doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(name="viewport" content="width=device-width, initial-scale=1.0")
        title Manage Vendor Services | HMS Pro
        link(rel="preconnect" href="https://fonts.googleapis.com")
        link(rel="preconnect" href="https://fonts.gstatic.com" crossorigin)
        link(href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&display=swap" rel="stylesheet")
        link(rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css")
        link(rel="stylesheet" href="/css/style.css")
        style.
            body { display: flex; overflow: hidden; height: 100vh; }
            .content { flex-grow: 1; overflow-y: auto; padding: 2rem 3rem; }
            .vendor-img-mini { width: 40px; height: 40px; border-radius: 8px; object-fit: cover; background: var(--bg-dark); }
    body
        nav.sidebar
            div.logo
                i.fas.fa-building-circle-check
                span HMS Pro
            ul.nav-links
                li(onclick="window.location.href='/owner/dashboard'")
                    i.fas.fa-chart-pie
                    span Dashboard
                li(onclick="window.location.href='/owner/halls'")
                    i.fas.fa-hotel
                    span My Halls
                li(onclick="window.location.href='/owner/add-hall'")
                    i.fas.fa-plus-circle
                    span Add Hall
                li.active(onclick="window.location.href='/owner/vendors'")
                    i.fas.fa-handshake
                    span Vendors
                li(onclick="window.location.href='/owner/queries'")
                    i.fas.fa-envelope-open-text
                    span Enquiries
                li(onclick="window.location.href='/owner/customers'")
                    i.fas.fa-users
                    span Customers
                li(onclick="window.location.href='/owner/profile'")
                    i.fas.fa-user-cog
                    span Profile
            
            div.user-profile
                div#owner-avatar.avatar ?
                div.info
                    p#owner_sidebar_name.name Loading...
                    p.role Hall Owner
        
        main.content
            header
                h1 Manage Vendor Services
                div.header-actions
                    button.btn.btn-primary(onclick="window.location.href='/owner/add-vendor'")
                        i.fas.fa-plus
                        |  Add New Vendor
            
            div.recent-card
                div.table-container
                    table#owner-vendors-table
                        thead
                            tr
                                th Image
                                th Vendor Name
                                th Category
                                th Staff
                                th Price
                                th Status
                                th Actions
                        tbody
                            tr
                                td(colspan="7") Loading your vendor services...

        script(src="/js/frontend.js")
        script.
            // Check auth
            const token = localStorage.getItem('hms_token');
            if (!token) window.location.href = '/owner/login';

            const owner = JSON.parse(localStorage.getItem('hms_owner') || '{}');
            document.getElementById('owner_sidebar_name').textContent = owner.name || 'Owner';
            document.getElementById('owner-avatar').textContent = (owner.name || 'O').charAt(0).toUpperCase();

            async function init() {
                const tableBody = document.querySelector('#owner-vendors-table tbody');
                const vendors = await HMS.fetchOwnerVendors();
                
                tableBody.innerHTML = vendors.length ? vendors.map(vendor => `
                    <tr>
                        <td>
                            <img src="${vendor.images && vendor.images.length > 0 ? vendor.images[0] : 'https://via.placeholder.com/100?text=No+Image'}" 
                                 class="vendor-img-mini" 
                                 onerror="this.src='https://via.placeholder.com/100?text=No+Image'">
                        </td>
                        <td><strong>${vendor.vendor_name}</strong></td>
                        <td><span class="badge" style="background: rgba(99, 102, 241, 0.1); color: var(--primary);">${vendor.category}</span></td>
                        <td>${vendor.staff}</td>
                        <td>Rs. ${vendor.starting_price.toLocaleString()}</td>
                        <td>
                            <span class="status ${vendor.is_public ? 'approved' : 'pending'}">
                                ${vendor.is_public ? 'Public' : 'Private'}
                            </span>
                        </td>
                        <td>
                            <div style="display: flex; gap: 0.5rem;">
                                <button class="btn-icon" title="${vendor.is_public ? 'Make Private' : 'Make Public'}" onclick="handleToggleStatus('${vendor._id}')">
                                    <i class="fas ${vendor.is_public ? 'fa-toggle-on' : 'fa-toggle-off'}" style="color: ${vendor.is_public ? 'var(--primary)' : 'var(--text-secondary)'}"></i>
                                </button>
                                <button class="btn-icon" title="Edit" onclick="window.location.href='/owner/edit-vendor/${vendor._id}'">
                                    <i class="fas fa-edit"></i>
                                </button>
                                <button class="btn-icon text-danger" title="Delete" onclick="handleDeleteVendor('${vendor._id}', '${vendor.vendor_name}')">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                `).join('') : '<tr><td colspan="7">No vendor services found. Add your first service!</td></tr>';
            }

            async function handleToggleStatus(id) {
                const success = await HMS.toggleVendorStatus(id);
                if (success) {
                    init(); 
                }
            }

            async function handleDeleteVendor(id, name) {
                if (confirm(`Are you sure you want to delete "${name}"? This action cannot be undone.`)) {
                    const success = await HMS.deleteVendor(id);
                    if (success) {
                        init();
                    }
                }
            }

            init();
