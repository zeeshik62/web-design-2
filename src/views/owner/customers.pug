doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(name="viewport" content="width=device-width, initial-scale=1.0")
        title My Customers | HMS Pro
        link(rel="preconnect" href="https://fonts.googleapis.com")
        link(rel="preconnect" href="https://fonts.gstatic.com" crossorigin)
        link(href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&display=swap" rel="stylesheet")
        link(rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css")
        link(rel="stylesheet" href="/css/style.css")
        style.
            body { display: flex; overflow: hidden; height: 100vh; }
            .content { flex-grow: 1; overflow-y: auto; padding: 2rem 3rem; }
            .filters-bar { display: flex; gap: 1rem; margin-bottom: 2rem; background: #fff; padding: 1.5rem; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); align-items: flex-end; }
            .filter-group { display: flex; flex-direction: column; gap: 0.5rem; flex: 1; }
            .filter-group label { font-size: 0.85rem; font-weight: 600; color: #666; }
            .filter-group input { padding: 0.6rem; border: 1px solid #ddd; border-radius: 6px; font-family: inherit; }
            .pagination { display: flex; gap: 0.5rem; justify-content: center; margin-top: 2rem; }
            .page-btn { padding: 0.5rem 1rem; border: 1px solid #ddd; background: #fff; border-radius: 6px; cursor: pointer; transition: all 0.2s; }
            .page-btn.active { background: var(--primary-color, #4a90e2); color: #fff; border-color: var(--primary-color, #4a90e2); }
            .page-btn:disabled { opacity: 0.5; cursor: not-allowed; }
            .customer-card { background: #fff; padding: 1.5rem; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem; }
            .customer-avatar { width: 50px; height: 50px; background: #e2e8f0; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; color: #475569; font-size: 1.2rem; }
            .customer-info h3 { margin: 0; font-size: 1.1rem;color: #666; }
            .customer-info p { margin: 0; color: #666; font-size: 0.9rem; }
    body
        nav.sidebar
            div.logo
                i.fas.fa-building-circle-check
                span HMS Pro
            ul.nav-links
                li(onclick="window.location.href='/owner/dashboard'")
                    i.fas.fa-chart-pie
                    span Dashboard
                li(onclick="window.location.href='/owner/halls'")
                    i.fas.fa-hotel
                    span My Halls
                li(onclick="window.location.href='/owner/add-hall'")
                    i.fas.fa-plus-circle
                    span Add Hall
                li(onclick="window.location.href='/owner/vendors'")
                    i.fas.fa-handshake
                    span Vendors
                li(onclick="window.location.href='/owner/queries'")
                    i.fas.fa-envelope-open-text
                    span Enquiries
                li.active(onclick="window.location.href='/owner/customers'")
                    i.fas.fa-users
                    span Customers
                li(onclick="window.location.href='/owner/profile'")
                    i.fas.fa-user-cog
                    span Profile
            
            div.user-profile
                div#owner-avatar.avatar AD
                div.info
                    p#owner-name.name Loading...
                    p.role Hall Owner
        
        main.content
            header
                h1 My Customers
                p Customers who have inquired about your halls.
            
            div.filters-bar
                div.filter-group
                    label(for="customer_name") Customer Name
                    input#filter-name(type="text" placeholder="Search by name...")
                button.btn.btn-primary#btn-filter
                    i.fas.fa-search
                    |  Filter
                button.btn.btn-outline#btn-reset
                    | Reset

            div#customers-list
                p(style="text-align: center;") Loading customers...

            div#pagination.pagination

        script(src="/js/frontend.js")
        script.
            let currentPage = 1;
            const limit = 10;

            // Check auth
            const token = localStorage.getItem('hms_token');
            if (!token) window.location.href = '/owner/login';

            const owner = JSON.parse(localStorage.getItem('hms_owner') || '{}');
            document.getElementById('owner-name').textContent = owner.name || 'Owner';
            document.getElementById('owner-avatar').textContent = (owner.name || 'O').charAt(0).toUpperCase();

            async function loadCustomers(page = 1) {
                currentPage = page;
                const name = document.getElementById('filter-name').value;
                
                let url = `/api/hall_owner/customers?page=${page}&limit=${limit}`;
                if (name) url += `&name=${encodeURIComponent(name)}`;

                try {
                    const response = await fetch(url, {
                        headers: { 'Authorization': `Bearer ${token}` }
                    });
                    const result = await response.json();

                    if (result.success) {
                        displayCustomers(result.data);
                        setupPagination(result.pagination);
                    } else {
                        alert('Error: ' + result.message);
                    }
                } catch (err) {
                    console.error('Fetch error:', err);
                }
            }

            function displayCustomers(customers) {
                const container = document.getElementById('customers-list');
                if (!customers.length) {
                    container.innerHTML = '<p style="text-align: center; margin-top: 2rem; color: #666;">No customers found.</p>';
                    return;
                }

                container.innerHTML = customers.map(cust => `
                    <div class="customer-card">
                        <div class="customer-avatar">${(cust.name || 'C').charAt(0).toUpperCase()}</div>
                        <div class="customer-info">
                            <h3>${cust.name}</h3>
                            <p><i class="fas fa-envelope"></i> ${cust.email}</p>
                        </div>
                        <div style="margin-left: auto;">
                            <button class="btn btn-outline" onclick="window.location.href='/owner/queries?customer_name=${encodeURIComponent(cust.name)}'">
                                View Queries
                            </button>
                        </div>
                    </div>
                `).join('');
            }

            function setupPagination(meta) {
                const container = document.getElementById('pagination');
                if (meta.totalPages <= 1) {
                    container.innerHTML = '';
                    return;
                }

                let html = `
                    <button class="page-btn" ${meta.page === 1 ? 'disabled' : ''} onclick="loadCustomers(${meta.page - 1})">Prev</button>
                `;

                for (let i = 1; i <= meta.totalPages; i++) {
                    html += `<button class="page-btn ${meta.page === i ? 'active' : ''}" onclick="loadCustomers(${i})">${i}</button>`;
                }

                html += `
                    <button class="page-btn" ${meta.page === meta.totalPages ? 'disabled' : ''} onclick="loadCustomers(${meta.page + 1})">Next</button>
                `;

                container.innerHTML = html;
            }

            document.getElementById('btn-filter').addEventListener('click', () => loadCustomers(1));
            document.getElementById('btn-reset').addEventListener('click', () => {
                document.getElementById('filter-name').value = '';
                loadCustomers(1);
            });

            loadCustomers();
