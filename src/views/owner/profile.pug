doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(name="viewport" content="width=device-width, initial-scale=1.0")
        title My Profile | HMS Pro
        link(rel="preconnect" href="https://fonts.googleapis.com")
        link(rel="preconnect" href="https://fonts.gstatic.com" crossorigin)
        link(href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&display=swap" rel="stylesheet")
        link(rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css")
        link(rel="stylesheet" href="/css/style.css")
        style.
            body { display: flex; overflow: hidden; height: 100vh; }
            .content { flex-grow: 1; overflow-y: auto; padding: 2rem 3rem; }
            .profile-grid { display: grid; grid-template-columns: 300px 1fr; gap: 2rem; align-items: start; }
            .profile-card { background: var(--card-bg); padding: 2.5rem; border-radius: 24px; border: 1px solid var(--border); text-align: center; }
            .profile-avatar-large { width: 150px; height: 150px; border-radius: 50%; background: var(--primary); color: #fff; font-size: 4rem; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem; border: 4px solid var(--bg-dark); object-fit: cover; }
            .form-section { background: var(--card-bg); padding: 2.5rem; border-radius: 24px; border: 1px solid var(--border); }
            .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
            .full-width { grid-column: span 2; }
            .form-group { margin-bottom: 1.5rem; text-align: left; }
            .form-group label { display: block; margin-bottom: 0.5rem; color: var(--text-secondary); font-size: 0.9rem; }
            .form-control { width: 100%; background: var(--bg-dark); border: 1px solid var(--border); padding: 0.75rem 1rem; border-radius: 12px; color: #fff; outline: none; transition: all 0.3s; }
            .form-control:focus { border-color: var(--primary); box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.1); }
            .form-control:disabled { opacity: 0.6; cursor: not-allowed; }
            .status-toggle { display: flex; align-items: center; gap: 1rem; padding: 1rem; background: var(--bg-dark); border-radius: 12px; margin-top: 1rem; border: 1px solid var(--border); }
            .switch { position: relative; display: inline-block; width: 50px; height: 26px; }
            .switch input { opacity: 0; width: 0; height: 0; }
            .slider { position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background-color: #4b5563; transition: .4s; border-radius: 34px; }
            .slider:before { position: absolute; content: ""; height: 18px; width: 18px; left: 4px; bottom: 4px; background-color: white; transition: .4s; border-radius: 50%; }
            input:checked + .slider { background-color: var(--primary); }
            input:checked + .slider:before { transform: translateX(24px); }
    body
        nav.sidebar
            div.logo
                i.fas.fa-building-circle-check
                span HMS Pro
            ul.nav-links
                li(onclick="window.location.href='/owner/dashboard'")
                    i.fas.fa-chart-pie
                    span Dashboard
                li(onclick="window.location.href='/owner/halls'")
                    i.fas.fa-hotel
                    span My Halls
                li(onclick="window.location.href='/owner/add-hall'")
                    i.fas.fa-plus-circle
                    span Add Hall
                li(onclick="window.location.href='/owner/vendors'")
                    i.fas.fa-handshake
                    span Vendors
                li(onclick="window.location.href='/owner/queries'")
                    i.fas.fa-envelope-open-text
                    span Enquiries
                li(onclick="window.location.href='/owner/customers'")
                    i.fas.fa-users
                    span Customers
                li.active(onclick="window.location.href='/owner/profile'")
                    i.fas.fa-user-cog
                    span Profile
            
            div.user-profile
                div#owner-avatar-sidebar.avatar ??
                div.info
                    p#owner-name-sidebar.name Loading...
                    p.role Hall Owner

        main.content
            header
                h1 Profile Settings
                div.header-actions
                    button.btn.btn-primary#update-profile-btn
                        i.fas.fa-check-circle
                        |  Update Profile
            
            div.profile-grid
                div.profile-card
                    id#profile-image-container
                        div#profile-avatar-display.profile-avatar-large ??
                    h2#display-brand-name Loading...
                    p#display-email.text-secondary Loading...
                    
                    div.status-toggle
                        span Public Profile
                        label.switch
                            input#is_public(type="checkbox")
                            span.slider
                        span#status-label.badge.status-pending Private

                div.form-section
                    form#profile-form
                        div.form-grid
                            div.form-group
                                label Full Name
                                input.form-control#name(type="text" required)
                            div.form-group
                                label Brand Name
                                input.form-control#brand_name(type="text" required)
                            div.form-group
                                label Email Address (Readonly)
                                input.form-control#email(type="email" disabled)
                            div.form-group
                                label Contact Number
                                input.form-control#contact(type="text" required)
                            div.form-group.full-width
                                label Profile Image URL
                                input.form-control#image_url(type="url" placeholder="https://example.com/photo.jpg")
                            
                            div.form-group.full-width(style="margin-top: 1rem; margin-bottom: 0.5rem;")
                                h3(style="font-size: 1.1rem; color: var(--primary);") Business Location
                            
                            div.form-group.full-width
                                label Street Address
                                input.form-control#street_address(type="text" required)
                            div.form-group
                                label City
                                input.form-control#city(type="text" required)
                            div.form-group
                                label Country
                                input.form-control#country(type="text" required)

        script(src="/js/frontend.js")
        script.
            const token = localStorage.getItem('hms_token');
            if (!token) window.location.href = '/owner/login';

            async function initProfile() {
                const owner = await HMS.fetchOwnerProfile();
                if (!owner) return;

                // Sync sidebar
                document.getElementById('owner-name-sidebar').textContent = owner.name;
                document.getElementById('owner-avatar-sidebar').textContent = owner.name.charAt(0).toUpperCase();

                // Fill Form
                document.getElementById('name').value = owner.name;
                document.getElementById('brand_name').value = owner.brand_name;
                document.getElementById('email').value = owner.email;
                document.getElementById('contact').value = owner.contact;
                document.getElementById('image_url').value = owner.image || '';
                document.getElementById('street_address').value = owner.address.street_address;
                document.getElementById('city').value = owner.address.city;
                document.getElementById('country').value = owner.address.country;
                document.getElementById('is_public').checked = owner.is_public;

                // Display Info
                document.getElementById('display-brand-name').textContent = owner.brand_name;
                document.getElementById('display-email').textContent = owner.email;
                updateStatusLabel(owner.is_public);

                // Avatar Display
                const avatar = document.getElementById('profile-avatar-display');
                if (owner.image) {
                    avatar.innerHTML = `<img src="${owner.image}" style="width:100%; height:100%; border-radius:50%; object-fit:cover;">`;
                    avatar.style.background = 'transparent';
                } else {
                    avatar.textContent = owner.name.charAt(0).toUpperCase();
                }
            }

            function updateStatusLabel(isPublic) {
                const label = document.getElementById('status-label');
                label.textContent = isPublic ? 'Public' : 'Private';
                label.className = `badge status ${isPublic ? 'approved' : 'pending'}`;
            }

            document.getElementById('is_public').addEventListener('change', (e) => {
                updateStatusLabel(e.target.checked);
            });

            document.getElementById('update-profile-btn').addEventListener('click', async () => {
                const profileData = {
                    name: document.getElementById('name').value,
                    brand_name: document.getElementById('brand_name').value,
                    contact: document.getElementById('contact').value,
                    image: document.getElementById('image_url').value,
                    is_public: document.getElementById('is_public').checked,
                    address: {
                        street_address: document.getElementById('street_address').value,
                        city: document.getElementById('city').value,
                        country: document.getElementById('country').value
                    }
                };

                const success = await HMS.updateOwnerProfile(profileData);
                if (success) {
                    initProfile(); // Reload to reflect changes
                }
            });

            initProfile();
