extends ../layout

block styles
    style.
        .auth-box {
            max-width: 500px;
            margin: 4rem auto;
            background: var(--card-bg);
            padding: 3rem;
            border-radius: 20px;
            border: 1px solid var(--border);
            box-shadow: 0 20px 40px rgba(0,0,0,0.4);
        }
        .auth-box h1 {
            text-align: center;
            margin-bottom: 2rem;
            font-size: 2rem;
        }
        .form-group {
            margin-bottom: 1.5rem;
        }
        .form-group label {
            display: block;
            margin-bottom: 0.5rem;
            color: var(--text-secondary);
            font-size: 0.9rem;
        }
        .form-control {
            width: 100%;
            background: var(--bg-dark);
            border: 1px solid var(--border);
            padding: 0.75rem 1rem;
            border-radius: 10px;
            color: #fff;
            outline: none;
            transition: border-color 0.3s;
        }
        .form-control:focus {
            border-color: var(--primary);
        }
        .auth-btn {
            width: 100%;
            padding: 1rem;
            margin-top: 1rem;
            font-size: 1rem;
        }
        .auth-footer {
            margin-top: 2rem;
            text-align: center;
            color: var(--text-secondary);
            font-size: 0.9rem;
        }
        .auth-footer a {
            color: var(--primary);
            text-decoration: none;
        }

block content
    div.container
        div.auth-box
            h1 Owner Registration
            form#register-form
                div.form-group
                    label(for="name") Full Name
                    input#name.form-control(type="text" placeholder="John Doe" required)
                div.form-group
                    label(for="brand_name") Brand / Business Name
                    input#brand_name.form-control(type="text" placeholder="Royal Banquets" required)
                div.form-group
                    label(for="email") Email Address
                    input#email.form-control(type="email" placeholder="owner@example.com" required)
                div.form-group
                    label(for="password") Password
                    input#password.form-control(type="password" placeholder="••••••••" required)
                div.form-group
                    label(for="contact") Contact Number
                    input#contact.form-control(type="text" placeholder="+1234567890" required)
                div.form-group
                    label(for="street_address") Street Address
                    input#street_address.form-control(type="text" placeholder="123 Main St" required)
                div.form-group(style="display: flex; gap: 1rem;")
                    div(style="flex: 1;")
                        label(for="city") City
                        input#city.form-control(type="text" placeholder="New York" required)
                    div(style="flex: 1;")
                        label(for="country") Country
                        input#country.form-control(type="text" placeholder="USA" required)
                button.btn.btn-primary.auth-btn(type="submit") Create Account
            
            div.auth-footer
                p Already have an account? 
                    a(href="/owner/login") Login here

    div#otp-modal(style="display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.7); z-index: 2000; align-items: center; justify-content: center;")
        div(style="background: var(--card-bg); padding: 2.5rem; border-radius: 20px; width: 100%; max-width: 400px; border: 1px solid var(--border); position: relative;")
            span(onclick="document.getElementById('otp-modal').style.display='none'" style="position: absolute; top: 1rem; right: 1.5rem; cursor: pointer; color: var(--text-secondary); font-size: 1.5rem;") &times;
            h2(style="margin-bottom: 1rem; text-align: center;") Verify Account
            p.text-secondary(style="margin-bottom: 1.5rem; text-align: center;") Thanks for registering! Enter the OTP sent to your email to verify.
            form#otp-form
                input#otp-email(type="hidden")
                div.form-group
                    input#otp-code.form-control(type="text" placeholder="Enter 6-digit OTP" required style="text-align: center; font-size: 1.25rem; letter-spacing: 5px;")
                button.btn.btn-primary.auth-btn(type="submit") Verify & Login

block scripts
    script.
        const registerForm = document.getElementById('register-form');
        registerForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const data = {
                name: document.getElementById('name').value,
                brand_name: document.getElementById('brand_name').value,
                email: document.getElementById('email').value,
                password: document.getElementById('password').value,
                contact: document.getElementById('contact').value,
                address: {
                    street_address: document.getElementById('street_address').value,
                    city: document.getElementById('city').value,
                    country: document.getElementById('country').value
                }
            };
            
            const result = await HMS.registerOwner(data);
            if (result.success) {
                document.getElementById('otp-email').value = result.email;
                document.getElementById('otp-modal').style.display = 'flex';
            }
        });

        const otpForm = document.getElementById('otp-form');
        otpForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const email = document.getElementById('otp-email').value;
            const otpCode = document.getElementById('otp-code').value;
            const verified = await HMS.verifyOwner(email, otpCode);
            if (verified) {
                window.location.href = '/owner/dashboard';
            }
        });
