doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(name="viewport" content="width=device-width, initial-scale=1.0")
        title My Halls | HMS Pro
        link(rel="preconnect" href="https://fonts.googleapis.com")
        link(rel="preconnect" href="https://fonts.gstatic.com" crossorigin)
        link(href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&display=swap" rel="stylesheet")
        link(rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css")
        link(rel="stylesheet" href="/css/style.css")
        style.
            body { display: flex; overflow: hidden; height: 100vh; }
            .content { flex-grow: 1; overflow-y: auto; padding: 2rem 3rem; }
    body
        nav.sidebar
            div.logo
                i.fas.fa-building-circle-check
                span HMS Pro
            ul.nav-links
                li(onclick="window.location.href='/owner/dashboard'")
                    i.fas.fa-chart-pie
                    span Dashboard
                li.active(onclick="window.location.href='/owner/halls'")
                    i.fas.fa-hotel
                    span My Halls
                li(onclick="window.location.href='/owner/add-hall'")
                    i.fas.fa-plus-circle
                    span Add Hall
                li(onclick="window.location.href='/owner/queries'")
                    i.fas.fa-envelope-open-text
                    span Enquiries
                li(onclick="window.location.href='/owner/customers'")
                    i.fas.fa-users
                    span Customers
            
            div.user-profile
                div#owner-avatar.avatar AD
                div.info
                    p#owner-name.name Loading...
                    p.role Hall Owner
        
        main.content
            header
                h1 Manage My Halls
                div.header-actions
                    button.btn.btn-primary(onclick="window.location.href='/owner/add-hall'")
                        i.fas.fa-plus
                        |  Add New Hall
            
            div.recent-card
                div.table-container
                    table#owner-halls-table
                        thead
                            tr
                                th Hall Name
                                th Type
                                th Capacity
                                th City
                                th Status
                                th Actions
                        tbody
                            tr
                                td(colspan="6") Loading your halls...

        script(src="/js/frontend.js")
        script.
            // Check auth
            const token = localStorage.getItem('hms_token');
            if (!token) window.location.href = '/owner/login';

            const owner = JSON.parse(localStorage.getItem('hms_owner') || '{}');
            document.getElementById('owner-name').textContent = owner.name || 'Owner';
            document.getElementById('owner-avatar').textContent = (owner.name || 'O').charAt(0).toUpperCase();

            // HMS.renderOwnerHalls() is already defined in frontend.js but we call it here to ensure it runs correctly
            async function init() {
                const tableBody = document.querySelector('#owner-halls-table tbody');
                const halls = await HMS.fetchOwnerHalls();
                tableBody.innerHTML = halls.length ? halls.map(hall => `
                    <tr>
                        <td><strong>${hall.subhall_name}</strong></td>
                        <td>${hall.type}</td>
                        <td>${hall.sitting_capacity} Guests</td>
                        <td>${hall.address.city}</td>
                        <td>
                            <span class="status ${hall.is_public ? 'approved' : 'pending'}">
                                ${hall.is_public ? 'Public' : 'Private'}
                            </span>
                        </td>
                        <td>
                            <div style="display: flex; gap: 0.5rem;">
                                <button class="btn-icon" title="${hall.is_public ? 'Disable/Hide from Public' : 'Enable/Show to Public'}" onclick="handleToggleStatus('${hall._id}')">
                                    <i class="fas ${hall.is_public ? 'fa-toggle-on' : 'fa-toggle-off'}" style="color: ${hall.is_public ? 'var(--primary)' : 'var(--text-secondary)'}"></i>
                                </button>
                                <button class="btn-icon" title="Edit" onclick="window.location.href='/owner/edit-hall/${hall._id}'"><i class="fas fa-edit"></i></button>
                                <button class="btn-icon text-danger" title="Delete" onclick="handleDeleteHall('${hall._id}', '${hall.subhall_name}')"><i class="fas fa-trash"></i></button>
                            </div>
                        </td>
                    </tr>
                `).join('') : '<tr><td colspan="6">No halls found. Add your first one!</td></tr>';
            }

            async function handleToggleStatus(id) {
                const success = await HMS.toggleHallStatus(id);
                if (success) {
                    init(); // Refresh the list
                }
            }

            async function handleDeleteHall(id, name) {
                if (confirm(`Are you sure you want to delete "${name}"? This action cannot be undone.`)) {
                    const success = await HMS.deleteHall(id);
                    if (success) {
                        init(); // Refresh the list
                    }
                }
            }

            init();
