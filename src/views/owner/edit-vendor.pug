doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(name="viewport" content="width=device-width, initial-scale=1.0")
        title Edit Vendor Service | HMS Pro
        link(rel="preconnect" href="https://fonts.googleapis.com")
        link(rel="preconnect" href="https://fonts.gstatic.com" crossorigin)
        link(href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&display=swap" rel="stylesheet")
        link(rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css")
        link(rel="stylesheet" href="/css/style.css")
        style.
            body { display: flex; overflow: hidden; height: 100vh; }
            .content { flex-grow: 1; overflow-y: auto; padding: 2rem 3rem; }
            .form-section { background: var(--card-bg); padding: 2.5rem; border-radius: 20px; border: 1px solid var(--border); margin-bottom: 2rem; }
            .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
            .full-width { grid-column: span 2; }
            .form-group { margin-bottom: 1.5rem; }
            .form-group label { display: block; margin-bottom: 0.5rem; color: var(--text-secondary); font-size: 0.9rem; }
            .form-control { width: 100%; background: var(--bg-dark); border: 1px solid var(--border); padding: 0.75rem 1rem; border-radius: 10px; color: #fff; outline: none; transition: border-color 0.3s; }
            .form-control:focus { border-color: var(--primary); }
            .image-upload-wrapper { display: flex; flex-wrap: wrap; gap: 1rem; margin-top: 1rem; }
            .image-preview { width: 120px; height: 120px; border-radius: 12px; border: 2px dashed var(--border); display: flex; align-items: center; justify-content: center; position: relative; overflow: hidden; }
            .image-preview img { width: 100%; height: 100%; object-fit: cover; }
            .image-preview .remove-img { position: absolute; top: 5px; right: 5px; background: rgba(239, 68, 68, 0.8); color: white; width: 24px; height: 24px; border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer; font-size: 12px; }
            .upload-btn { width: 120px; height: 120px; border-radius: 12px; border: 2px dashed var(--border); display: flex; flex-direction: column; align-items: center; justify-content: center; cursor: pointer; transition: all 0.3s; color: var(--text-secondary); }
            .upload-btn:hover { border-color: var(--primary); color: var(--primary); background: rgba(99, 102, 241, 0.05); }
            .upload-btn i { font-size: 1.5rem; margin-bottom: 0.5rem; }
    body
        nav.sidebar
            div.logo
                i.fas.fa-building-circle-check
                span HMS Pro
            ul.nav-links
                li(onclick="window.location.href='/owner/dashboard'")
                    i.fas.fa-chart-pie
                    span Dashboard
                li(onclick="window.location.href='/owner/halls'")
                    i.fas.fa-hotel
                    span My Halls
                li(onclick="window.location.href='/owner/add-hall'")
                    i.fas.fa-plus-circle
                    span Add Hall
                li.active(onclick="window.location.href='/owner/vendors'")
                    i.fas.fa-handshake
                    span Vendors
                li(onclick="window.location.href='/owner/queries'")
                    i.fas.fa-envelope-open-text
                    span Enquiries
                li(onclick="window.location.href='/owner/customers'")
                    i.fas.fa-users
                    span Customers
                li(onclick="window.location.href='/owner/profile'")
                    i.fas.fa-user-cog
                    span Profile
            
            div.user-profile
                div#owner-avatar.avatar ?
                div.info
                    p#owner_sidebar_name.name Loading...
                    p.role Hall Owner

        main.content
            header
                h1 Edit Vendor Service
                div.header-actions
                    button.btn.btn-primary#save-btn
                        i.fas.fa-save
                        |  Update Service
            
            form#edit-vendor-form
                section.form-section
                    h2 Basic Information
                    div.form-grid
                        div.form-group
                            label Vendor/Service Name
                            input.form-control#vendor_name(type="text" placeholder="e.g. Elegant Captures" required)
                        div.form-group
                            label Service Category
                            select.form-control#category(required)
                                option(value="Caterer") Caterer
                                option(value="Photographer") Photographer
                                option(value="Decorator") Decorator
                                option(value="DJ") DJ
                                option(value="Live Band") Live Band
                                option(value="Event Planner") Event Planner
                                option(value="Make-up Artist") Make-up Artist
                        div.form-group
                            label Staff Provided
                            select.form-control#staff(required)
                                option(value="Both") Both (Male & Female)
                                option(value="Male") Male Only
                                option(value="Female") Female Only
                        div.form-group
                            label Starting Price (Rs.)
                            input.form-control#starting_price(type="number" placeholder="15000" required min="0")
                        div.form-group
                            label Discount Percentage (%)
                            input.form-control#discount(type="number" placeholder="5" min="0" max="100")

                section.form-section
                    h2 Location & Service Area
                    div.form-grid
                        div.form-group.full-width
                            label Office/Street Address
                            input.form-control#street_address(type="text" placeholder="123 Studio Street" required)
                        div.form-group
                            label City
                            input.form-control#city(type="text" placeholder="Lahore" required)
                        div.form-group
                            label Country
                            input.form-control#country(type="text" placeholder="Pakistan" required)

                section.form-section
                    h2 Media & Details
                    div.form-group
                        label Service Description & Instructions
                        textarea.form-control#instructions(rows="4" placeholder="Describe your service packages, rules, or any special offers...")
                    
                    div.form-group
                        label Service Images
                        div.image-upload-wrapper#image-wrapper
                            div.upload-btn#upload-trigger
                                i.fas.fa-cloud-upload-alt
                                span Upload
                                input#file-input(type="file" accept="image/*" style="display: none;")

        script(src="/js/frontend.js")
        script.
            const token = localStorage.getItem('hms_token');
            if (!token) window.location.href = '/owner/login';

            const owner = JSON.parse(localStorage.getItem('hms_owner') || '{}');
            document.getElementById('owner_sidebar_name').textContent = owner.name || 'Owner';
            document.getElementById('owner-avatar').textContent = (owner.name || 'O').charAt(0).toUpperCase();

            const vendorId = window.location.pathname.split('/').pop();
            let uploadedImages = [];

            async function loadVendor() {
                const vendor = await HMS.fetchVendorById(vendorId);
                if (!vendor) {
                    HMS.notify('Vendor not found', 'error');
                    setTimeout(() => window.location.href = '/owner/vendors', 1500);
                    return;
                }

                document.getElementById('vendor_name').value = vendor.vendor_name;
                document.getElementById('category').value = vendor.category;
                document.getElementById('staff').value = vendor.staff;
                document.getElementById('starting_price').value = vendor.starting_price;
                document.getElementById('discount').value = vendor.discount || '';
                document.getElementById('street_address').value = vendor.address.street_address;
                document.getElementById('city').value = vendor.address.city;
                document.getElementById('country').value = vendor.address.country;
                document.getElementById('instructions').value = vendor.instructions || '';
                
                uploadedImages = vendor.images || [];
                renderPreviews();
            }

            // Image logic (identical to add-vendor)
            const fileInput = document.getElementById('file-input');
            const uploadTrigger = document.getElementById('upload-trigger');
            const imageWrapper = document.getElementById('image-wrapper');

            uploadTrigger.onclick = () => fileInput.click();

            fileInput.onchange = async (e) => {
                const file = e.target.files[0];
                if (!file) return;
                
                uploadTrigger.style.pointerEvents = 'none';
                uploadTrigger.innerHTML = '<i class="fas fa-spinner fa-spin"></i><span>Uploading...</span>';

                const imagePath = await HMS.uploadImage(file, 'vendor');
                
                uploadTrigger.style.pointerEvents = 'auto';
                uploadTrigger.innerHTML = '<i class="fas fa-cloud-upload-alt"></i><span>Upload</span>';

                if (imagePath) {
                    uploadedImages.push(imagePath);
                    renderPreviews();
                }
                fileInput.value = '';
            };

            function renderPreviews() {
                const existing = document.querySelectorAll('.image-preview');
                existing.forEach(el => el.remove());

                uploadedImages.forEach((path, index) => {
                    const preview = document.createElement('div');
                    preview.className = 'image-preview';
                    preview.innerHTML = `
                        <img src="${path}" onerror="this.src='https://via.placeholder.com/120?text=Error'">
                        <div class="remove-img" onclick="removeImage(${index})"><i class="fas fa-times"></i></div>
                    `;
                    imageWrapper.insertBefore(preview, uploadTrigger);
                });
            }

            window.removeImage = (index) => {
                uploadedImages.splice(index, 1);
                renderPreviews();
            };

            // Update handler
            document.getElementById('save-btn').onclick = async () => {
                const vendorData = {
                    vendor_name: document.getElementById('vendor_name').value.trim(),
                    category: document.getElementById('category').value,
                    staff: document.getElementById('staff').value,
                    starting_price: parseInt(document.getElementById('starting_price').value) || 0,
                    discount: parseInt(document.getElementById('discount').value) || null,
                    address: {
                        street_address: document.getElementById('street_address').value.trim(),
                        city: document.getElementById('city').value.trim(),
                        country: document.getElementById('country').value.trim()
                    },
                    instructions: document.getElementById('instructions').value.trim(),
                    images: uploadedImages
                };

                const btn = document.getElementById('save-btn');
                btn.disabled = true;
                btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Updating...';

                const success = await HMS.updateVendor(vendorId, vendorData);
                if (success) {
                    window.location.href = '/owner/vendors';
                } else {
                    btn.disabled = false;
                    btn.innerHTML = '<i class="fas fa-save"></i> Update Service';
                }
            };

            loadVendor();
