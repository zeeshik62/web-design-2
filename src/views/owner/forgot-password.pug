extends ../layout

block styles
    style.
        .auth-box {
            max-width: 450px;
            margin: 6rem auto;
            background: var(--card-bg);
            padding: 3rem;
            border-radius: 20px;
            border: 1px solid var(--border);
            box-shadow: 0 20px 40px rgba(0,0,0,0.4);
        }
        .auth-box h1 {
            text-align: center;
            margin-bottom: 2rem;
            font-size: 2rem;
        }
        .form-group {
            margin-bottom: 1.5rem;
        }
        .form-group label {
            display: block;
            margin-bottom: 0.5rem;
            color: var(--text-secondary);
            font-size: 0.9rem;
        }
        .form-control {
            width: 100%;
            background: var(--bg-dark);
            border: 1px solid var(--border);
            padding: 0.75rem 1rem;
            border-radius: 10px;
            color: #fff;
            outline: none;
            transition: border-color 0.3s;
        }
        .form-control:focus {
            border-color: var(--primary);
        }
        .auth-btn {
            width: 100%;
            padding: 1rem;
            margin-top: 1rem;
            font-size: 1rem;
        }
        .auth-footer {
            margin-top: 2rem;
            text-align: center;
            color: var(--text-secondary);
            font-size: 0.9rem;
        }
        .auth-footer a {
            color: var(--primary);
            text-decoration: none;
        }

block content
    div.container
        div.auth-box
            h1 Forgot Password
            p.text-secondary(style="margin-bottom: 2rem; text-align: center;") Enter your registered email to receive a password reset OTP.
            form#forgot-password-form
                div.form-group
                    label(for="email") Email Address
                    input#email.form-control(type="email" placeholder="owner@example.com" required)
                button.btn.btn-primary.auth-btn(type="submit") Send OTP
            
            div.auth-footer
                p Remembered your password? 
                    a(href="/owner/login") Back to Login

block scripts
    script.
        const forgotForm = document.getElementById('forgot-password-form');
        forgotForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const email = document.getElementById('email').value;
            
            const success = await HMS.forgotPassword(email);
            if (success) {
                // Store email in sessionStorage to pass it to the reset password page
                sessionStorage.setItem('reset_email', email);
                window.location.href = '/owner/reset-password';
            }
        });
