extends ../layout

block styles
    style.
        .auth-box {
            max-width: 450px;
            margin: 6rem auto;
            background: var(--card-bg);
            padding: 3rem;
            border-radius: 20px;
            border: 1px solid var(--border);
            box-shadow: 0 20px 40px rgba(0,0,0,0.4);
        }
        .auth-box h1 {
            text-align: center;
            margin-bottom: 2rem;
            font-size: 2rem;
        }
        .form-group {
            margin-bottom: 1.5rem;
        }
        .form-group label {
            display: block;
            margin-bottom: 0.5rem;
            color: var(--text-secondary);
            font-size: 0.9rem;
        }
        .form-control {
            width: 100%;
            background: var(--bg-dark);
            border: 1px solid var(--border);
            padding: 0.75rem 1rem;
            border-radius: 10px;
            color: #fff;
            outline: none;
            transition: border-color 0.3s;
        }
        .form-control:focus {
            border-color: var(--primary);
        }
        .auth-btn {
            width: 100%;
            padding: 1rem;
            margin-top: 1rem;
            font-size: 1rem;
        }
        .auth-footer {
            margin-top: 2rem;
            text-align: center;
            color: var(--text-secondary);
            font-size: 0.9rem;
        }
        .auth-footer a {
            color: var(--primary);
            text-decoration: none;
        }

block content
    div.container
        div.auth-box
            h1 Reset Password
            p.text-secondary(style="margin-bottom: 2rem; text-align: center;") Enter the OTP sent to your email and your new password.
            form#reset-password-form
                div.form-group
                    label(for="email") Email Address
                    input#email.form-control(type="email" placeholder="owner@example.com" required readonly)
                div.form-group
                    label(for="otp") OTP Code
                    input#otp.form-control(type="text" placeholder="123456" required)
                div.form-group
                    label(for="newPassword") New Password
                    input#newPassword.form-control(type="password" placeholder="••••••••" required)
                button.btn.btn-primary.auth-btn(type="submit") Reset Password
            
            div.auth-footer
                p Wait, I remembered! 
                    a(href="/owner/login") Back to Login

block scripts
    script.
        // Pre-fill email from sessionStorage if available
        const resetEmail = sessionStorage.getItem('reset_email');
        if (resetEmail) {
            document.getElementById('email').value = resetEmail;
        } else {
            // If no email in session, allow user to type or redirect back
            document.getElementById('email').removeAttribute('readonly');
        }

        const resetForm = document.getElementById('reset-password-form');
        resetForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const data = {
                email: document.getElementById('email').value,
                otp: document.getElementById('otp').value,
                newPassword: document.getElementById('newPassword').value
            };
            
            const success = await HMS.resetPassword(data);
            if (success) {
                sessionStorage.removeItem('reset_email');
                window.location.href = '/owner/login';
            }
        });
