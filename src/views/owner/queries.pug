doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(name="viewport" content="width=device-width, initial-scale=1.0")
        title Manage Enquiries | HMS Pro
        link(rel="preconnect" href="https://fonts.googleapis.com")
        link(rel="preconnect" href="https://fonts.gstatic.com" crossorigin)
        link(href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&display=swap" rel="stylesheet")
        link(rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css")
        link(rel="stylesheet" href="/css/style.css")
        style.
            body { display: flex; overflow: hidden; height: 100vh; }
            .content { flex-grow: 1; overflow-y: auto; padding: 2rem 3rem; }
            .filters-bar { display: flex; gap: 1rem; margin-bottom: 2rem; background: #fff; padding: 1.5rem; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); align-items: flex-end; }
            .filter-group { display: flex; flex-direction: column; gap: 0.5rem; flex: 1; }
            .filter-group label { font-size: 0.85rem; font-weight: 600; color: #666; }
            .filter-group input, .filter-group select { padding: 0.6rem; border: 1px solid #ddd; border-radius: 6px; font-family: inherit; }
            .pagination { display: flex; gap: 0.5rem; justify-content: center; margin-top: 2rem; }
            .page-btn { padding: 0.5rem 1rem; border: 1px solid #ddd; background: #fff; border-radius: 6px; cursor: pointer; transition: all 0.2s; }
            .page-btn.active { background: var(--primary-color, #4a90e2); color: #fff; border-color: var(--primary-color, #4a90e2); }
            .page-btn:disabled { opacity: 0.5; cursor: not-allowed; }
            .status-badge { padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.8rem; font-weight: 600; text-transform: capitalize; }
            .status-pending { background: #fff3cd; color: #856404; }
            .status-responded { background: #d4edda; color: #155724; }
            .status-spam { background: #f8d7da; color: #721c24; }
            .description-cell { max-width: 250px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; cursor: pointer; color: #666; font-size: 0.9rem; }
            .description-cell:hover { white-space: normal; color: #333; }
    body
        nav.sidebar
            div.logo
                i.fas.fa-building-circle-check
                span HMS Pro
            ul.nav-links
                li(onclick="window.location.href='/owner/dashboard'")
                    i.fas.fa-chart-pie
                    span Dashboard
                li(onclick="window.location.href='/owner/halls'")
                    i.fas.fa-hotel
                    span My Halls
                li(onclick="window.location.href='/owner/add-hall'")
                    i.fas.fa-plus-circle
                    span Add Hall
                li.active(onclick="window.location.href='/owner/queries'")
                    i.fas.fa-envelope-open-text
                    span Enquiries
                li(onclick="window.location.href='/owner/customers'")
                    i.fas.fa-users
                    span Customers
                li(onclick="window.location.href='/owner/profile'")
                    i.fas.fa-user-cog
                    span Profile
            
            div.user-profile
                div#owner-avatar.avatar AD
                div.info
                    p#owner-name.name Loading...
                    p.role Hall Owner
        
        main.content
            header
                h1 Manage Enquiries
                p Track and respond to user queries for your halls.
            
            div.filters-bar
                div.filter-group
                    label(for="customer_name") Customer Name
                    input#filter-customer(type="text" placeholder="Search by name...")
                div.filter-group
                    label(for="status") Status
                    select#filter-status
                        option(value="") All Statuses
                        option(value="pending") Pending
                        option(value="responded") Responded
                        option(value="spam") Spam
                button.btn.btn-primary#btn-filter
                    i.fas.fa-search
                    |  Filter
                button.btn.btn-outline#btn-reset
                    | Reset

            div.recent-card
                div.table-container
                    table#enquiries-table
                        thead
                            tr
                                th Customer
                                th Hall
                                th Date
                                th Description
                                th Status
                                th Action
                        tbody
                            tr
                                td(colspan="5" style="text-align: center;") Loading enquiries...

                div#pagination.pagination

        script(src="/js/frontend.js")
        script.
            let currentPage = 1;
            const limit = 10;

            // Check auth
            const token = localStorage.getItem('hms_token');
            if (!token) window.location.href = '/owner/login';

            const owner = JSON.parse(localStorage.getItem('hms_owner') || '{}');
            document.getElementById('owner-name').textContent = owner.name || 'Owner';
            document.getElementById('owner-avatar').textContent = (owner.name || 'O').charAt(0).toUpperCase();

            async function loadEnquiries(page = 1) {
                currentPage = page;
                const status = document.getElementById('filter-status').value;
                const customerName = document.getElementById('filter-customer').value;
                
                let url = `/api/hall_owner/enquiries?page=${page}&limit=${limit}`;
                if (status) url += `&status=${status}`;
                if (customerName) url += `&customer_name=${encodeURIComponent(customerName)}`;

                try {
                    const response = await fetch(url, {
                        headers: { 'Authorization': `Bearer ${token}` }
                    });
                    const result = await response.json();

                    if (result.success) {
                        displayEnquiries(result.data);
                        setupPagination(result.pagination);
                    } else {
                        alert('Error: ' + result.message);
                    }
                } catch (err) {
                    console.error('Fetch error:', err);
                }
            }

            function displayEnquiries(enquiries) {
                const tbody = document.querySelector('#enquiries-table tbody');
                if (!enquiries.length) {
                    tbody.innerHTML = '<tr><td colspan="5" style="text-align: center;">No enquiries found.</td></tr>';
                    return;
                }

                tbody.innerHTML = enquiries.map(enq => `
                    <tr>
                        <td>
                            <div style="display: flex; flex-direction: column;">
                                <strong>${enq.customer_id ? enq.customer_id.name : 'Unknown'}</strong>
                                <small style="color: #666;">${enq.customer_id ? enq.customer_id.email : '-'}</small>
                            </div>
                        </td>
                        <td>${enq.hall_id ? enq.hall_id.subhall_name : 'Deleted Venue'}</td>
                        <td>${new Date(enq.date).toLocaleDateString()}</td>
                        <td>
                            <div class="description-cell" title="${enq.description || ''}">${enq.description || 'No description'}</div>
                        </td>
                        <td>
                            <span class="status-badge status-${enq.status}">${enq.status}</span>
                        </td>
                        <td>
                            <select onchange="updateStatus('${enq._id}', this.value)" style="padding: 0.3rem; border-radius: 4px;">
                                <option value="pending" ${enq.status === 'pending' ? 'selected' : ''}>Pending</option>
                                <option value="responded" ${enq.status === 'responded' ? 'selected' : ''}>Responded</option>
                                <option value="spam" ${enq.status === 'spam' ? 'selected' : ''}>Spam</option>
                            </select>
                        </td>
                    </tr>
                `).join('');
            }

            async function updateStatus(id, newStatus) {
                try {
                    const response = await fetch(`/api/hall_owner/enquiries/${id}/status`, {
                        method: 'PATCH',
                        headers: {
                            'Content-Type': 'application/json',
                            'Authorization': `Bearer ${token}`
                        },
                        body: JSON.stringify({ status: newStatus })
                    });
                    const result = await response.json();
                    if (result.success) {
                        loadEnquiries(currentPage);
                    } else {
                        alert('Failed to update status: ' + result.message);
                    }
                } catch (err) {
                    console.error('Update error:', err);
                }
            }

            function setupPagination(meta) {
                const container = document.getElementById('pagination');
                if (meta.totalPages <= 1) {
                    container.innerHTML = '';
                    return;
                }

                let html = `
                    <button class="page-btn" ${meta.page === 1 ? 'disabled' : ''} onclick="loadEnquiries(${meta.page - 1})">Prev</button>
                `;

                for (let i = 1; i <= meta.totalPages; i++) {
                    html += `<button class="page-btn ${meta.page === i ? 'active' : ''}" onclick="loadEnquiries(${i})">${i}</button>`;
                }

                html += `
                    <button class="page-btn" ${meta.page === meta.totalPages ? 'disabled' : ''} onclick="loadEnquiries(${meta.page + 1})">Next</button>
                `;

                container.innerHTML = html;
            }

            document.getElementById('btn-filter').addEventListener('click', () => loadEnquiries(1));
            document.getElementById('btn-reset').addEventListener('click', () => {
                document.getElementById('filter-customer').value = '';
                document.getElementById('filter-status').value = '';
                loadEnquiries(1);
            });

            loadEnquiries();
