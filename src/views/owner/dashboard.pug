doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(name="viewport" content="width=device-width, initial-scale=1.0")
        title Owner Dashboard | HMS Pro
        link(rel="preconnect" href="https://fonts.googleapis.com")
        link(rel="preconnect" href="https://fonts.gstatic.com" crossorigin)
        link(href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&display=swap" rel="stylesheet")
        link(rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css")
        link(rel="stylesheet" href="/css/style.css")
        style.
            body { display: flex; overflow: hidden; height: 100vh; }
            .content { flex-grow: 1; overflow-y: auto; padding: 2rem 3rem; }
    body
        nav.sidebar
            div.logo
                i.fas.fa-building-circle-check
                span HMS Pro
            ul.nav-links
                li.active(onclick="window.location.href='/owner/dashboard'")
                    i.fas.fa-chart-pie
                    span Dashboard
                li(onclick="window.location.href='/owner/halls'")
                    i.fas.fa-hotel
                    span My Halls
                li(onclick="window.location.href='/owner/add-hall'")
                    i.fas.fa-plus-circle
                    span Add Hall
                li(onclick="window.location.href='/owner/vendors'")
                    i.fas.fa-handshake
                    span Vendors
                li(onclick="window.location.href='/owner/queries'")
                    i.fas.fa-envelope-open-text
                    span Enquiries
                li(onclick="window.location.href='/owner/customers'")
                    i.fas.fa-users
                    span Customers
                li(onclick="window.location.href='/owner/profile'")
                    i.fas.fa-user-cog
                    span Profile
            
            div.user-profile
                div#owner-avatar.avatar AD
                div.info
                    p#owner-name.name Loading...
                    p.role Hall Owner
                button.btn-icon(onclick="HMS.logout()" style="margin-left: auto; border: none; background: transparent;")
                    i.fas.fa-sign-out-alt
        
        main.content
            header
                h1 Dashboard Overview
                div.header-actions
                    button.btn.btn-primary(onclick="window.location.href='/owner/add-hall'")
                        i.fas.fa-plus
                        |  New Hall
            
            section.stats-grid
                div.stat-card
                    div.stat-icon.blue
                        i.fas.fa-hotel
                    div.stat-info
                        h3 Total Halls
                        p#total-halls.count 0
                div.stat-card
                    div.stat-icon.purple
                        i.fas.fa-envelope-open-text
                    div.stat-info
                        h3 New Enquiries
                        p#total-enquiries.count 0
                div.stat-card
                    div.stat-icon.orange
                        i.fas.fa-users
                    div.stat-info
                        h3 Total Customers
                        p#total-customers.count 0

            div.recent-card
                h2 Recent Activity
                div.table-container
                    table
                        thead
                            tr
                                th Event
                                th Date
                                th Status
                        tbody
                            tr
                                td New Hall "Grand Ballroom" added
                                td 2026-04-12
                                td: span.status.approved Completed
                            tr
                                td Enquiry received for "Oceanic Marquee"
                                td 2026-04-13
                                td: span.status.pending Pending

        script(src="/js/frontend.js")
        script.
            // Check auth
            const token = localStorage.getItem('hms_token');
            if (!token) window.location.href = '/owner/login';

            const owner = JSON.parse(localStorage.getItem('hms_owner') || '{}');
            document.getElementById('owner-name').textContent = owner.name || 'Owner';
            document.getElementById('owner-avatar').textContent = (owner.name || 'O').charAt(0).toUpperCase();

            async function loadStats() {
                try {
                    const response = await fetch('/api/hall_owner/stats', {
                        headers: { 'Authorization': `Bearer ${token}` }
                    });
                    const result = await response.json();
                    if (result.success) {
                        document.getElementById('total-halls').textContent = result.data.totalHalls;
                        document.getElementById('total-enquiries').textContent = result.data.totalEnquiries;
                        document.getElementById('total-customers').textContent = result.data.totalCustomers;
                    }
                } catch (err) {
                    console.error('Error loading stats:', err);
                }
            }

            async function loadPendingEnquiries() {
                const tbody = document.querySelector('table tbody');
                try {
                    const response = await fetch('/api/hall_owner/enquiries?status=pending&limit=5', {
                        headers: { 'Authorization': `Bearer ${token}` }
                    });
                    const result = await response.json();
                    
                    if (result.success && result.data.length > 0) {
                        tbody.innerHTML = result.data.map(enq => `
                            <tr>
                                <td>Enquiry from "${enq.customer_id ? enq.customer_id.name : 'User'}" for "${enq.hall_id ? enq.hall_id.subhall_name : 'Hall'}"</td>
                                <td>${new Date(enq.date).toLocaleDateString()}</td>
                                <td><span class="status-pending status">Pending</span></td>
                            </tr>
                        `).join('');
                    } else {
                        tbody.innerHTML = '<tr><td colspan="3" style="text-align: center;">No pending enquiries at the moment.</td></tr>';
                    }
                } catch (err) {
                    console.error('Error loading enquiries:', err);
                    tbody.innerHTML = '<tr><td colspan="3" style="text-align: center;">Error loading data.</td></tr>';
                }
            }

            loadStats();
            loadPendingEnquiries();
