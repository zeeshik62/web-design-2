doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(name="viewport" content="width=device-width, initial-scale=1.0")
        title Owner Dashboard | HMS Pro
        link(rel="preconnect" href="https://fonts.googleapis.com")
        link(rel="preconnect" href="https://fonts.gstatic.com" crossorigin)
        link(href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&display=swap" rel="stylesheet")
        link(rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css")
        link(rel="stylesheet" href="/css/style.css")
        style.
            body { display: flex; overflow: hidden; height: 100vh; }
            .content { flex-grow: 1; overflow-y: auto; padding: 2rem 3rem; }
    body
        nav.sidebar
            div.logo
                i.fas.fa-building-circle-check
                span HMS Pro
            ul.nav-links
                li.active(onclick="window.location.href='/owner/dashboard'")
                    i.fas.fa-chart-pie
                    span Dashboard
                li(onclick="window.location.href='/owner/halls'")
                    i.fas.fa-hotel
                    span My Halls
                li(onclick="window.location.href='/owner/add-hall'")
                    i.fas.fa-plus-circle
                    span Add Hall
                li(onclick="window.location.href='/owner/vendors'")
                    i.fas.fa-handshake
                    span Vendors
                li(onclick="window.location.href='/owner/queries'")
                    i.fas.fa-envelope-open-text
                    span Enquiries
                li(onclick="window.location.href='/owner/customers'")
                    i.fas.fa-users
                    span Customers
                li(onclick="window.location.href='/owner/profile'")
                    i.fas.fa-user-cog
                    span Profile
            
            div.user-profile
                div#owner-avatar.avatar AD
                div.info
                    p#owner-name.name Loading...
                    p.role Hall Owner
                button.btn-icon(onclick="HMS.logout()" style="margin-left: auto; border: none; background: transparent;")
                    i.fas.fa-sign-out-alt
        
        main.content
            header
                h1 Dashboard Overview
                div.header-actions
                    button.btn.btn-primary(onclick="window.location.href='/owner/add-hall'")
                        i.fas.fa-plus
                        |  New Hall
            
            section.stats-grid
                div.stat-card
                    div.stat-icon.blue
                        i.fas.fa-hotel
                    div.stat-info
                        h3 Total Halls
                        p#total-halls.count 0
                div.stat-card
                    div.stat-icon.purple
                        i.fas.fa-handshake
                    div.stat-info
                        h3 Total Vendors
                        p#total-vendors.count 0
                div.stat-card
                    div.stat-icon.orange
                        i.fas.fa-envelope-open-text
                    div.stat-info
                        h3 Global Enquiries
                        p#total-enquiries.count 0
                div.stat-card
                    div.stat-icon.blue(style="background: rgba(34, 197, 94, 0.1); color: #22c55e;")
                        i.fas.fa-users
                    div.stat-info
                        h3 Total Customers
                        p#total-customers.count 0

            div.recent-card
                div(style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;")
                    h2 Recent Enquiries
                    a(href="/owner/queries" style="color: var(--primary); text-decoration: none; font-size: 0.9rem; font-weight: 600;") View All
                div.table-container
                    table
                        thead
                            tr
                                th Type
                                th Details
                                th Date
                                th Status
                        tbody
                            tr
                                td(colspan="4" style="text-align: center; padding: 2rem;")
                                    i.fas.fa-circle-notch.fa-spin(style="margin-right: 0.5rem;")
                                    | Loading...

        script(src="/js/frontend.js")
        script.
            // Check auth
            const token = localStorage.getItem('hms_token');
            if (!token) window.location.href = '/owner/login';

            const owner = JSON.parse(localStorage.getItem('hms_owner') || '{}');
            document.getElementById('owner-name').textContent = owner.name || 'Owner';
            document.getElementById('owner-avatar').textContent = (owner.name || 'O').charAt(0).toUpperCase();

            async function loadStats() {
                try {
                    const response = await fetch('/api/hall_owner/stats', {
                        headers: { 'Authorization': `Bearer ${token}` }
                    });
                    const result = await response.json();
                    if (result.success) {
                        document.getElementById('total-halls').textContent = result.data.totalHalls;
                        document.getElementById('total-vendors').textContent = result.data.totalVendors;
                        document.getElementById('total-enquiries').textContent = result.data.combinedEnquiries;
                        document.getElementById('total-customers').textContent = result.data.totalCustomers;
                    }
                } catch (err) {
                    console.error('Error loading stats:', err);
                }
            }

            async function loadRecentEnquiries() {
                const tbody = document.querySelector('table tbody');
                try {
                    // Fetch both hall and vendor enquiries
                    const [hRes, vRes] = await Promise.all([
                        fetch('/api/hall_owner/enquiries?status=pending&limit=3', {
                            headers: { 'Authorization': `Bearer ${token}` }
                        }),
                        fetch('/api/hall_owner/vendor-enquiries?status=pending&limit=3', {
                            headers: { 'Authorization': `Bearer ${token}` }
                        })
                    ]);

                    const hData = await hRes.json();
                    const vData = await vRes.json();

                    let combined = [];
                    if (hData.success) {
                        combined = combined.concat(hData.data.map(enq => ({
                            type: 'Hall',
                            detail: `Enquiry from "${enq.customer_id?.name || 'User'}" for "${enq.hall_id?.subhall_name || 'Hall'}"`,
                            date: enq.date,
                            status: enq.status
                        })));
                    }
                    if (vData.success) {
                        combined = combined.concat(vData.data.map(q => ({
                            type: 'Vendor',
                            detail: `Enquiry from "${q.customer_id?.name || 'User'}" for "${q.vendor_id?.vendor_name || 'Vendor'}"`,
                            date: q.date,
                            status: q.status
                        })));
                    }

                    // Sort by newest
                    combined.sort((a, b) => new Date(b.date) - new Date(a.date));
                    const latest = combined.slice(0, 5);
                    
                    if (latest.length > 0) {
                        tbody.innerHTML = latest.map(item => `
                            <tr>
                                <td>
                                    <span style="padding: 0.2rem 0.6rem; border-radius: 6px; font-size: 0.75rem; font-weight: 700; background: ${item.type === 'Hall' ? 'rgba(99, 102, 241, 0.1)' : 'rgba(168, 85, 247, 0.1)'}; color: ${item.type === 'Hall' ? 'var(--primary)' : 'var(--accent-purple)'};">
                                        ${item.type}
                                    </span>
                                </td>
                                <td style="max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">${item.detail}</td>
                                <td style="white-space: nowrap;">${new Date(item.date).toLocaleDateString()}</td>
                                <td><span class="status-pending status">${item.status}</span></td>
                            </tr>
                        `).join('');
                    } else {
                        tbody.innerHTML = '<tr><td colspan="4" style="text-align: center; padding: 2rem;">No new enquiries.</td></tr>';
                    }
                } catch (err) {
                    console.error('Error loading enquiries:', err);
                    tbody.innerHTML = '<tr><td colspan="4" style="text-align: center; color: #ef4444; padding: 2rem;">Error loading data.</td></tr>';
                }
            }

            loadStats();
            loadRecentEnquiries();
