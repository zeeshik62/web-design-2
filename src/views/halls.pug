extends layout

block content
    div.container
        div.page-header
            h1 Discover Halls
            p.text-secondary(style="font-size: 1.1rem;") Browse through our collection of premium venues for your next event.

        div.filters-container
            div.filter-bar
                div.filter-item
                    label Hall Name
                    div.input-with-icon
                        i.fas.fa-magnifying-glass
                        input#filter-name(type="text" placeholder="Search by name...")
                
                div.filter-item
                    label City
                    div.input-with-icon
                        i.fas.fa-city
                        input#filter-city(type="text" placeholder="City")
                
                div.filter-item
                    label Location
                    div.input-with-icon
                        i.fas.fa-location-dot
                        input#filter-location(type="text" placeholder="Street/Area")
                
                div.filter-item
                    label Hall Type
                    div.input-with-icon
                        i.fas.fa-building
                        select#filter-type
                            option(value="") All Types
                            option(value="Marquee") Marquee
                            option(value="Banquet Hall") Banquet Hall
                            option(value="Conference Room") Conference Room
                            option(value="Open Roof") Open Roof
                            option(value="Other") Other

                div.filter-item
                    label Min Price
                    div.input-with-icon
                        i.fas.fa-dollar-sign
                        input#filter-min-price(type="number" placeholder="Min Price")

                div.filter-item
                    label Max Price
                    div.input-with-icon
                        i.fas.fa-dollar-sign
                        input#filter-max-price(type="number" placeholder="Max Price")

                div.filter-item
                    label Special Offers
                    div.input-with-icon
                        i.fas.fa-tag
                        select#filter-discount
                            option(value="") All Venues
                            option(value="true") With Discount
                            option(value="false") No Discount
                
                button.btn-primary#apply-filters
                    i.fas.fa-filter
                    span Filter

        div#halls-grid.grid
            //- Data will be injected here via frontend.js
            div.loading-spinner(style="grid-column: 1 / -1; text-align: center; padding: 4rem 0; color: var(--text-secondary);")
                i.fas.fa-circle-notch.fa-spin(style="font-size: 2rem; color: var(--primary); margin-bottom: 1rem; display: block;")
                span Loading venues...

block scripts
    script.
        document.addEventListener('DOMContentLoaded', () => {
            // Check for URL parameters to pre-fill filters
            const urlParams = new URLSearchParams(window.location.search);
            const city = urlParams.get('city');
            const street = urlParams.get('street');
            const name = urlParams.get('search');
            const type = urlParams.get('type');
            const minPrice = urlParams.get('min_price');
            const maxPrice = urlParams.get('max_price');
            const hasDiscount = urlParams.get('has_discount');

            if (city) document.getElementById('filter-city').value = city;
            if (street) document.getElementById('filter-location').value = street;
            if (name) document.getElementById('filter-name').value = name;
            if (type) document.getElementById('filter-type').value = type;
            if (minPrice) document.getElementById('filter-min-price').value = minPrice;
            if (maxPrice) document.getElementById('filter-max-price').value = maxPrice;
            if (hasDiscount) document.getElementById('filter-discount').value = hasDiscount;

            // Initial render call will be handled by frontend.js or triggered here
            if (window.renderHallListing) {
                const filters = {
                    city: city || '',
                    street: street || '',
                    search: name || '',
                    type: type || '',
                    min_price: minPrice || '',
                    max_price: maxPrice || '',
                    has_discount: hasDiscount || ''
                };
                window.renderHallListing(filters);
            }

            // Apply filters button
            document.getElementById('apply-filters').addEventListener('click', () => {
                const filters = {
                    search: document.getElementById('filter-name').value.trim(),
                    city: document.getElementById('filter-city').value.trim(),
                    street: document.getElementById('filter-location').value.trim(),
                    type: document.getElementById('filter-type').value,
                    min_price: document.getElementById('filter-min-price').value,
                    max_price: document.getElementById('filter-max-price').value,
                    has_discount: document.getElementById('filter-discount').value
                };
                
                if (window.renderHallListing) {
                    window.renderHallListing(filters);
                    
                    // Update URL without refreshing for better UX
                    const newUrl = new URL(window.location);
                    Object.keys(filters).forEach(key => {
                        if (filters[key]) newUrl.searchParams.set(key, filters[key]);
                        else newUrl.searchParams.delete(key);
                    });
                    window.history.pushState({}, '', newUrl);
                }
            });
        });
